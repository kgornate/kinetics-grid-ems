{
  "gateway": {
    "id": "northbound_ems_gateway_dev",
    "name": "NorthBound EMS Gateway",
    "mode": "read_only"
  },
  "network": {
    "field_interface": "eth1",
    "application_interface": "eth0"
  },
  "existing_ems": {
    "protocol": "modbus_tcp",
    "host": "127.0.0.1",
    "port": 515,
    "unit_id": 1,
    "register_function": "holding_registers",
    "timeout_sec": 2.0,
    "retries": 1
  },
  "register_map": {
    "path": "data/register_maps/china_ems_northbound_v1.json"
  },
  "decoding": {
    "data_type": "float32",
    "registers_per_point": 2,
    "byte_order": "ABCD",
    "apply_factor": true
  },
  "polling": {
    "enabled": true,
    "default_interval_sec": 5,
    "fast_interval_sec": 1,
    "slow_interval_sec": 10,
    "max_registers_per_read": 120
  },
  "api": {
    "host": "0.0.0.0",
    "port": 8000,
    "commands_enabled": false
  },
  "storage": {
    "enabled": true,
    "type": "sqlite",
    "path": "runtime/nb_ems_gateway.db"
  },
  "server_upload": {
    "enabled": false,
    "transport": "https_or_mqtt_future",
    "buffer_when_offline": true
  }
}
